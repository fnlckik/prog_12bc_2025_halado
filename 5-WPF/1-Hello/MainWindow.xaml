<Window x:Class="_1_Hello.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1_Hello"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="600"
        Width="1200"
        MinHeight="400"
        MinWidth="800">
    <!-- Komment -->
    <!-- XAML: eXtensible Application Markup Language -->
    <!-- Hotkey: CTRL + K + C (comment), CTRL + K + U (uncomment) -->
    <!-- Auto formázás: Tools -> Options -> Text Editor -> XAML -> Spacing -> ... -->
    <!-- CTRL + K + D -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0"
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Label VerticalAlignment="Center"
                       Background="White"
                       Grid.Column="0"
                       Content="Név:"
                       Padding="10"/>
                <TextBox Grid.Column="1"
                         x:Name="NameTextBox"
                         BorderBrush="Black"
                         Text=""
                         Padding="10"
                         MinWidth="100"
                         MaxWidth="200"
                         TextWrapping="Wrap"/>
            </StackPanel>
            <Button Width="200"
                    Height="100"
                    FontSize="24"
                    FontStyle="Italic"
                    FontWeight="Bold"
                    Click="Button_Click"
                    Margin="0,20,0,20"
                    Content="Kattints!" />
            <TextBlock x:Name="GreetingOutput"
                       Background="LightGray"
                       Padding="10"
                       Text="Üres köszönés..."
                       TextWrapping="Wrap"/>
        </StackPanel>
        <StackPanel Grid.Column="0"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <Button Content="Hozzáadás"
                    Padding="10"
                    Margin="10"
                    Click="AddButton_Click" />
            <Button Content="Szerkesztés"
                    Padding="10"
                    Margin="10" />
            <Button Content="Törlés"
                    Padding="10"
                    Margin="10" />
        </StackPanel>
        <ListBox Grid.Column="1"
                 Grid.Row="0"
                 Grid.RowSpan="2"
                 BorderBrush="Black"
                 MinWidth="200"
                 x:Name="NamesListBox">
            <ListBoxItem>Sándor</ListBoxItem>
            <ListBoxItem>József</ListBoxItem>
            <ListBoxItem>Benedek</ListBoxItem>
        </ListBox>
    </Grid>
</Window>
