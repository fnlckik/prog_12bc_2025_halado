<Window x:Class="_1_Hello.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1_Hello"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="600"
        Width="1200"
        MinHeight="400"
        MinWidth="400">
    <!-- Komment -->
    <!-- XAML: eXtensible Application Markup Language -->
    <!-- Hotkey: CTRL + K + C (comment), CTRL + K + U (uncomment) -->
    <!-- Auto formázás: Tools -> Options -> Text Editor -> XAML -> Spacing -> ... -->
    <!-- CTRL + K + D -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Label Content="Név:" />
            <TextBox x:Name="NameTextBox"
                     BorderBrush="Black"
                     Text=""
                     Padding="10" />
            <Button Width="200"
                    Height="100"
                    FontSize="24"
                    FontStyle="Italic"
                    FontWeight="Bold"
                    Click="Button_Click"
                    Margin="0,20,0,20"
                    Content="Kattints!" />
            <TextBlock x:Name="GreetingOutput"
                       Background="LightGray"
                       Padding="10"
                       Text="Üres köszönés..." />
        </StackPanel>
        <ListBox Grid.Column="1"
                 BorderBrush="Black"
                 MinWidth="200">
            <ListBoxItem>Sándor</ListBoxItem>
            <ListBoxItem>József</ListBoxItem>
            <ListBoxItem>Benedek</ListBoxItem>
        </ListBox>
    </Grid>
</Window>
