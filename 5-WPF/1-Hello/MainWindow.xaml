<Window x:Class="_1_Hello.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1_Hello"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800">
    <!-- Komment -->
    <!-- XAML: eXtensible Application Markup Language -->
    <!-- Hotkey: CTRL + K + C (comment), CTRL + K + U (uncomment) -->
    <!-- Auto formázás: Tools -> Options -> Text Editor -> XAML -> Spacing -> ... -->
    <!-- CTRL + K + D -->
    <Grid>
        <Button Width="200"
                Height="100"
                FontSize="24"
                Click="Button_Click">
            Kattints!
        </Button>
        <TextBlock Width="500"
                   Height="200"
                   Background="LightPink"
                   Panel.ZIndex="-1">
            Köszönés ide kerül...
        </TextBlock>
    </Grid>
</Window>
